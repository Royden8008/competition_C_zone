<launch>
  <!--
    Convenience launch: brings up the user's existing competition stack
    plus the safe_landing node. Edit the includes to match your actual
    launch files. By default we just include safe_landing.launch.
  -->

  <arg name="config" default="$(find safe_landing)/config/safe_landing.yaml"/>

  <!-- Uncomment the includes you actually have built in cwkj_ws or here: -->
  <!--
  <include file="$(find robot_bringup)/launch/px4.launch"/>
  <include file="$(find livox_ros_driver2)/launch/msg_MID360.launch"/>
  <include file="$(find fast_lio)/launch/mapping_mid360.launch"/>
  <include file="$(find ego_planner)/launch/single_run_in_sim.launch"/>
  <include file="$(find ar_track_alvar)/launch/pr2_indiv.launch"/>
  -->

  <include file="$(find safe_landing)/launch/safe_landing.launch">
    <arg name="config" value="$(arg config)"/>
    <arg name="rviz"   value="true"/>
  </include>
</launch>
